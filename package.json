{
  "name": "codify-vibathon-2026",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server.dev.js",
    "dev:local": "concurrently -n INNGEST,API,UI -c green,cyan,magenta \"bash -c 'sleep 4 && npx inngest-cli@latest dev -u http://localhost:3001/api/inngest'\" \"node server.dev.js\" \"vite\"",
    "dev:full": "concurrently -n API,UI -c cyan,magenta \"vercel dev --listen 3001\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.100.0",
    "inngest": "^4.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "vite": "^5.4.2"
  }
}
