{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/questionnaire.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/explain.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/test-claude.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/questionnaire", "dest": "api/questionnaire.js" },
    { "src": "/api/explain", "dest": "api/explain.js" },
    { "src": "/api/test-claude", "dest": "api/test-claude.js" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/docs", "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
